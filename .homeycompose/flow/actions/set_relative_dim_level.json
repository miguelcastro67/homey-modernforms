{
  "title": {
    "en": "Set relative dim level"
  },
  "titleFormatted": {
    "en": "Adjust dim level by [[amount]]"
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=fan"
    },
    {
      "type": "range",
      "name": "amount",
      "title": {
        "en": "(-100% to +100%)"
      },
      "min": -1,
      "max": 1,
      "step": 0.05,
      "labelMultiplier": 100,
      "labelDecimals": 0
    }
  ]
}
