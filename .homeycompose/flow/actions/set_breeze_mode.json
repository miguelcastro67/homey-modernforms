{
  "title": {
    "en": "Set breeze mode"
  },
  "titleFormatted": {
    "en": "Set breeze mode to [[mode]]"
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=fan"
    },
    {
      "type": "dropdown",
      "name": "mode",
      "title": {
        "en": "Mode"
      },
      "values": [
        {
          "id": "enabled",
          "label": {
            "en": "Enabled"
          }
        },
        {
          "id": "disabled",
          "label": {
            "en": "Disabled"
          }
        }
      ]
    }
  ]
}
